---
interface Props {
  src: string
  alt: string
  caption?: string
  size?: 'narrow' | 'wide' | 'full'
  width?: number
  height?: number
  priority?: boolean
}

const {
  src,
  alt,
  caption,
  size = 'wide',
  width,
  height,
  priority = false,
} = Astro.props

const sizeClassMap = {
  narrow: 'mx-auto max-w-2xl',
  wide: 'w-full',
  full: 'w-full md:-mx-12 md:w-[calc(100%+6rem)]',
} as const
---

<figure class:list={['my-8', sizeClassMap[size]]}>
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={priority ? 'eager' : 'lazy'}
    decoding="async"
    fetchpriority={priority ? 'high' : 'auto'}
  />
  {caption && <figcaption>{caption}</figcaption>}
</figure>
