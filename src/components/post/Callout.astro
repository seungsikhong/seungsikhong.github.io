---
interface Props {
  type?: 'note' | 'tip' | 'warning'
  title?: string
}

const {
  type = 'note',
  title,
} = Astro.props

const toneMap = {
  note: 'border-slate-300/80 bg-slate-50/80 text-slate-700 dark:border-slate-700/80 dark:bg-slate-900/40 dark:text-slate-200',
  tip: 'border-emerald-300/80 bg-emerald-50/85 text-emerald-800 dark:border-emerald-800/80 dark:bg-emerald-950/35 dark:text-emerald-100',
  warning: 'border-amber-300/80 bg-amber-50/85 text-amber-900 dark:border-amber-800/80 dark:bg-amber-950/35 dark:text-amber-100',
} as const
---

<aside class:list={['my-8 rounded-2xl border px-5 py-4', toneMap[type]]}>
  {title && <p class="mb-2 text-sm font-semibold tracking-[0.01em]">{title}</p>}
  <div class="text-sm leading-7">
    <slot />
  </div>
</aside>
