---
interface Heading {
  depth: number
  slug: string
  text: string
}

interface Props {
  headings?: Heading[]
}

const { headings = [] } = Astro.props
const toc = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3)
---

<div class="flex h-full flex-col overflow-y-auto px-4 py-4" data-right-rail>
  <section class="rounded-[1rem] border border-border/70 bg-transparent p-4">
    <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-primary" data-i18n="reading_eyebrow">읽기</p>
    <h2 class="mt-2 text-lg font-semibold tracking-tight text-foreground" data-i18n="reading_title">진행률</h2>
    <div class="mt-4 h-2 overflow-hidden rounded-full bg-muted" aria-hidden="true">
      <div
        class="h-full origin-left rounded-full bg-primary transition-transform duration-200"
        data-reading-progress-fill
        style="transform: scaleX(0)"
      ></div>
    </div>
    <div class="mt-3 flex items-center justify-between text-xs text-muted-foreground">
      <span data-reading-progress-label>0%</span>
      <span data-reading-progress-state data-i18n="reading_state_start">시작 전</span>
    </div>
  </section>

  <section class="mt-4 rounded-[1rem] border border-border/70 bg-transparent p-4">
    <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-primary" data-i18n="toc_eyebrow">구성</p>
    <h2 class="mt-2 text-lg font-semibold tracking-tight text-foreground" data-i18n="toc_title">목차</h2>
    {
      toc.length > 0 ? (
        <ol class="mt-4 space-y-1.5">
          {toc.map((heading) => (
            <li class:list={{ 'pl-3': heading.depth === 3 }}>
              <a
                class="toc-link block rounded-xl px-3 py-2 text-sm leading-5 text-muted-foreground transition hover:bg-accent hover:text-accent-foreground"
                href={`#${heading.slug}`}
                data-toc-link={heading.slug}
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <p class="mt-4 rounded-2xl border border-dashed border-border/70 bg-muted/60 px-4 py-4 text-sm leading-6 text-muted-foreground" data-i18n="toc_empty">
          표시할 목차가 아직 없습니다.
        </p>
      )
    }
  </section>
</div>

<script is:inline>
  (() => {
    const article = document.querySelector('[data-reading-area]')
    const progressFill = document.querySelector('[data-reading-progress-fill]')
    const progressLabel = document.querySelector('[data-reading-progress-label]')
    const progressState = document.querySelector('[data-reading-progress-state]')
    const links = Array.from(document.querySelectorAll('[data-toc-link]'))

    if (!(article instanceof HTMLElement) || !(progressFill instanceof HTMLElement)) {
      return
    }

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value))
    const updateProgress = () => {
      const rect = article.getBoundingClientRect()
      const articleTop = window.scrollY + rect.top
      const articleHeight = Math.max(article.offsetHeight - window.innerHeight, 1)
      const current = clamp(window.scrollY - articleTop, 0, articleHeight)
      const progress = current / articleHeight
      const percent = Math.round(progress * 100)

      progressFill.style.transform = `scaleX(${progress})`
      if (progressLabel) progressLabel.textContent = `${percent}%`

      if (progressState) {
        if (percent <= 5) {
          progressState.textContent = '시작 전'
        } else if (percent >= 95) {
          progressState.textContent = '마무리 중'
        } else {
          progressState.textContent = '읽는 중'
        }
      }
    }

    updateProgress()
    window.addEventListener('scroll', updateProgress, { passive: true })
    window.addEventListener('resize', updateProgress)

    if (links.length === 0) {
      return
    }

    const headingNodes = links
      .map((link) => {
        if (!(link instanceof HTMLAnchorElement)) return null
        const slug = link.dataset.tocLink
        if (!slug) return null
        const target = document.getElementById(slug)
        return target instanceof HTMLElement ? { link, target } : null
      })
      .filter(Boolean)

    const setActive = (slug) => {
      links.forEach((link) => {
        if (!(link instanceof HTMLAnchorElement)) return
        link.classList.toggle('is-active', link.dataset.tocLink === slug)
      })
    }

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)

        if (visible[0]?.target instanceof HTMLElement) {
          setActive(visible[0].target.id)
        }
      },
      {
        rootMargin: '-18% 0px -60% 0px',
        threshold: [0, 1],
      }
    )

    headingNodes.forEach((item) => observer.observe(item.target))
    if (headingNodes[0]) {
      setActive(headingNodes[0].target.id)
    }
  })()
</script>
