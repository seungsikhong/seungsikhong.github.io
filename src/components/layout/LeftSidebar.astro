---
import { FileText, FolderTree, House } from 'lucide-react'
import type { NavigationGroup } from '../../config/site'

interface SidebarStats {
  posts: number
  topics: number
  showVisits?: boolean
}

interface Props {
  groups: NavigationGroup[]
  pathname: string
  stats: SidebarStats
}

const { groups, pathname, stats } = Astro.props

function isActive(href: string) {
  if (href === '/') {
    return pathname === '/'
  }

  return pathname === href || pathname.startsWith(href)
}

const iconMap = {
  writing: FileText,
  topic: FolderTree,
} as const
---

<nav class="flex h-full flex-col overflow-y-auto px-3 py-5" aria-label="Primary">
  <div class="space-y-8">
    <div class="border-b border-border/70 px-2 pb-5">
      <a
        href="/"
        class="inline-flex items-center gap-2.5 text-[0.92rem] font-semibold tracking-[0.14em] text-foreground transition hover:text-primary"
        aria-label="Home"
      >
        <House className="size-4 text-muted-foreground" />
        <span data-i18n="nav_index">Index</span>
      </a>
    </div>

    {
      groups.map((group) => (
        <section class="space-y-3">
          {group.label && (
            <p
              class="px-3 text-[0.74rem] font-semibold uppercase tracking-[0.18em] text-muted-foreground"
              data-i18n={group.translationKey}
            >
              {group.label}
            </p>
          )}
          <ul class="space-y-2">
            {group.items.map((item) => {
              const active = isActive(item.href)
              const Icon = item.icon ? iconMap[item.icon] : null
              return (
                <li>
                  <a
                    class:list={[
                      'group flex items-center justify-between gap-3 rounded-2xl border px-4 py-3.5 transition duration-300',
                      active
                        ? 'border-primary/20 bg-primary/10 text-foreground shadow-[0_10px_24px_rgba(37,99,235,0.12)]'
                        : 'border-transparent text-muted-foreground hover:border-border/70 hover:bg-accent/70 hover:text-foreground',
                    ]}
                    href={item.href}
                    aria-current={active ? 'page' : undefined}
                  >
                    <span class="flex min-w-0 items-center gap-3">
                      {Icon && <Icon className="size-4 shrink-0 text-muted-foreground transition group-hover:text-foreground" />}
                      <span
                        class="block text-sm font-medium leading-6 tracking-[0.01em]"
                        data-i18n={item.translationKey}
                      >
                        {item.label}
                      </span>
                    </span>
                    {item.description && (
                      <span class="rounded-full bg-muted/80 px-2 py-0.5 text-[0.7rem] font-medium text-muted-foreground">
                        {item.description}
                      </span>
                    )}
                  </a>
                </li>
              )
            })}
          </ul>
        </section>
      ))
    }
  </div>

  <div class="mt-auto border-t border-border/70 px-3 pt-5">
    <dl class="space-y-3">
      <div class="flex items-center justify-between gap-4 text-sm">
        <dt class="text-muted-foreground" data-i18n="stats_posts">Posts</dt>
        <dd class="font-semibold text-foreground">{stats.posts}</dd>
      </div>
      <div class="flex items-center justify-between gap-4 text-sm">
        <dt class="text-muted-foreground" data-i18n="stats_topics">Categories</dt>
        <dd class="font-semibold text-foreground">{stats.topics}</dd>
      </div>
      {
        stats.showVisits && (
          <>
            <div class="flex items-center justify-between gap-4 text-sm">
              <dt class="text-muted-foreground" data-i18n="stats_today">Today</dt>
              <dd
                class="font-semibold text-foreground"
                data-goatcounter-count="TOTAL"
                data-goatcounter-render="number"
                data-goatcounter-start="today"
                data-goatcounter-fallback="—"
              >
                —
              </dd>
            </div>
            <div class="flex items-center justify-between gap-4 text-sm">
              <dt class="text-muted-foreground" data-i18n="stats_total">Total</dt>
              <dd
                class="font-semibold text-foreground"
                data-goatcounter-count="TOTAL"
                data-goatcounter-render="number"
                data-goatcounter-fallback="—"
              >
                —
              </dd>
            </div>
          </>
        )
      }
    </dl>
  </div>
</nav>
