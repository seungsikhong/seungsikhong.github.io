---
import SiteLayout from '../layouts/SiteLayout.astro'
import { getPublishedPosts } from '../utils/content'
import { formatDate } from '../utils/date'
import { getPostHref } from '../utils/posts'
import { getCategoryHref } from '../utils/taxonomy'

const posts = (await getPublishedPosts()).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
)
const featuredPosts = posts.slice(0, 3)
---

<SiteLayout title="Home" description="Code and thoughts. Still building.">
  <div class="mx-auto flex w-full max-w-5xl flex-col gap-8">
    <section class="relative overflow-hidden rounded-[1.8rem] border border-border/70 bg-card/92 p-8 md:p-11">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-primary/35 to-transparent"></div>
      <h1
        class="max-w-3xl text-4xl font-semibold tracking-[-0.03em] text-foreground md:text-[3.2rem] md:leading-[1.06]"
        data-i18n="home_title"
      >
        Code and thoughts.
      </h1>
      <p class="mt-6 max-w-2xl text-[1.02rem] leading-8 text-muted-foreground" data-i18n="home_description">
        Still building.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          class="home-cta"
          href="/posts/"
          data-i18n="home_cta_writing"
        >
          Read writing
        </a>
      </div>
    </section>

    <section class="rounded-[1.8rem] border border-border/70 bg-card/92 p-6 md:p-8">
      <div class="flex flex-col gap-3 border-b border-border/70 pb-5 md:flex-row md:items-end md:justify-between">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight text-foreground" data-i18n="home_recent_title">Latest posts</h2>
        </div>
        <a class="home-section-link" href="/posts/" data-i18n="home_recent_all">
          View all posts
        </a>
      </div>

      {
        featuredPosts.length === 0 ? (
          <div class="px-1 py-12">
            <h3 class="text-xl font-semibold tracking-tight text-foreground" data-i18n="empty_posts_title">
              No posts yet.
            </h3>
            <p class="mt-3 max-w-xl text-sm leading-7 text-muted-foreground" data-i18n="empty_posts_description">
              The first notes will land here soon.
            </p>
          </div>
        ) : (
          <div class="mt-2 divide-y divide-border/70">
            {
              featuredPosts.map((post) => (
                <article class="grid gap-3 rounded-xl py-5 transition hover:bg-accent/25 hover:px-4 md:grid-cols-[minmax(0,1fr)_10rem] md:items-start">
                  <div>
                    <p>
                      <a
                        class="text-xs font-semibold uppercase tracking-[0.16em] text-primary transition hover:text-primary/80"
                        href={getCategoryHref(post.data.category)}
                      >
                        {post.data.category}
                      </a>
                    </p>
                    <h3 class="mt-2 text-xl font-semibold tracking-tight text-foreground">
                      <a class="transition hover:text-primary" href={getPostHref(post)}>
                        {post.data.title}
                      </a>
                    </h3>
                    <p class="mt-3 max-w-2xl text-sm leading-6 text-muted-foreground">
                      {post.data.excerpt}
                    </p>
                  </div>

                  <div class="flex items-center justify-between gap-2 text-sm text-muted-foreground md:flex-col md:items-end md:justify-start md:pt-1">
                    <span>{formatDate(post.data.publishedAt)}</span>
                    <span
                      data-goatcounter-count={getPostHref(post)}
                      data-goatcounter-render="views"
                      data-goatcounter-fallback="—"
                    >
                      —
                    </span>
                    <span data-i18n={post.data.comments ? 'comment_on' : 'comment_off'}>
                      {post.data.comments ? 'Comments on' : 'Comments off'}
                    </span>
                  </div>
                </article>
              ))
            }
          </div>
        )
      }
    </section>
  </div>
</SiteLayout>
