---
import SiteLayout from '../../layouts/SiteLayout.astro'
import { getPublishedPosts } from '../../utils/content'
import { formatDate } from '../../utils/date'
import { getPostHref } from '../../utils/posts'
import { getCategoryHref } from '../../utils/taxonomy'

const posts = (await getPublishedPosts()).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
)
---

<SiteLayout title="글" description="개발 과정에서 남긴 기술 기록과 생각을 최신순으로 모았습니다.">
  <div class="mx-auto flex w-full max-w-5xl flex-col gap-8">
    <section class="border-b border-border/70 pb-8">
      <h1 class="text-4xl font-semibold tracking-[-0.03em] text-foreground md:text-[3.3rem]">
        글
      </h1>
      <p class="mt-6 max-w-2xl text-[1.05rem] leading-8 text-muted-foreground">
        개발 과정에서 남긴 기술 기록과 생각을 최신순으로 모았습니다.
      </p>
    </section>

    <section>
      {
        posts.length === 0 ? (
          <div class="border border-border/70 bg-card/50 px-6 py-12">
            <h2 class="text-xl font-semibold tracking-tight text-foreground">
              아직 글이 없습니다.
            </h2>
            <p class="mt-3 max-w-xl text-sm leading-7 text-muted-foreground">
              첫 기록이 곧 올라올 예정입니다.
            </p>
          </div>
        ) : (
          <div class="divide-y divide-border/70">
            {
              posts.map((post) => (
                <article class="grid gap-4 rounded-[1.5rem] py-5 transition hover:bg-accent/35 hover:px-4 md:grid-cols-[minmax(0,1fr)_10rem] md:items-start">
                  <div>
                    <p>
                      <a
                        class="text-xs font-semibold uppercase tracking-[0.16em] text-primary transition hover:text-primary/80"
                        href={getCategoryHref(post.data.category)}
                      >
                        {post.data.category}
                      </a>
                    </p>
                    <h2 class="mt-2 text-2xl font-semibold tracking-tight text-foreground">
                      <a class="transition hover:text-primary" href={getPostHref(post)}>
                        {post.data.title}
                      </a>
                    </h2>
                    <p class="mt-3 max-w-2xl text-sm leading-7 text-muted-foreground">
                      {post.data.excerpt}
                    </p>
                  </div>

                  <div class="flex items-center justify-between gap-2 text-sm text-muted-foreground md:flex-col md:items-end md:justify-start md:pt-1">
                    <span>{formatDate(post.data.publishedAt)}</span>
                    <span
                      data-goatcounter-count={getPostHref(post)}
                      data-goatcounter-render="views"
                      data-goatcounter-fallback="—"
                    >
                      —
                    </span>
                    <span>{post.data.comments ? '댓글 허용' : '댓글 없음'}</span>
                  </div>
                </article>
              ))
            }
          </div>
        )
      }
    </section>
  </div>
</SiteLayout>
