---
import SiteLayout from '../../layouts/SiteLayout.astro'
import { getPublishedPosts } from '../../utils/content'
import { formatDate } from '../../utils/date'
import { getPostHref } from '../../utils/posts'
import { buildCategoryItems, getCategorySlug } from '../../utils/taxonomy'

export async function getStaticPaths() {
  const posts = await getPublishedPosts()
  const categories = buildCategoryItems(posts)

  return categories.map((category) => ({
    params: { category: getCategorySlug(category.label) },
    props: { categoryName: category.label, count: category.count, posts },
  }))
}

const { categoryName, count, posts } = Astro.props
const filteredPosts = posts
  .filter((post) => post.data.category === categoryName)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
---

<SiteLayout
  title={categoryName}
  description={`${categoryName} · ${count}`}
>
  <div class="mx-auto flex w-full max-w-5xl flex-col gap-8">
    <section class="border-b border-border/70 pb-8">
      <h1 class="text-4xl font-semibold tracking-[-0.03em] text-foreground md:text-[3.1rem]">
        {categoryName}
      </h1>
      <p
        class="mt-6 max-w-2xl text-[1.02rem] leading-8 text-muted-foreground"
        data-i18n-template="topic_count"
        data-i18n-count={count}
      >
        Posts: {count}
      </p>
    </section>

    <section>
      <div class="divide-y divide-border/70">
        {
          filteredPosts.map((post) => (
            <article class="grid gap-4 rounded-xl py-5 transition hover:bg-accent/25 hover:px-4 md:grid-cols-[minmax(0,1fr)_10rem] md:items-start">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-primary">
                  {post.data.category}
                </p>
                <h2 class="mt-2 text-2xl font-semibold tracking-tight text-foreground">
                  <a class="transition hover:text-primary" href={getPostHref(post)}>
                    {post.data.title}
                  </a>
                </h2>
                <p class="mt-3 max-w-2xl text-sm leading-7 text-muted-foreground">
                  {post.data.excerpt}
                </p>
              </div>

              <div class="flex items-center justify-between gap-2 text-sm text-muted-foreground md:flex-col md:items-end md:justify-start md:pt-1">
                <span>{formatDate(post.data.publishedAt)}</span>
                <span
                  data-goatcounter-count={getPostHref(post)}
                  data-goatcounter-render="views"
                  data-goatcounter-fallback="—"
                >
                  —
                </span>
                <span data-i18n={post.data.comments ? 'comment_on' : 'comment_off'}>
                  {post.data.comments ? 'Comments on' : 'Comments off'}
                </span>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </div>
</SiteLayout>
