{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "blog:new",
      "type": "shell",
      "command": "npm run blog:new -- --title \"${input:postTitle}\" --category \"${input:postCategory}\" --tags \"${input:postTags}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "blog:meta",
      "type": "npm",
      "script": "blog:meta",
      "problemMatcher": []
    },
    {
      "label": "blog:image",
      "type": "shell",
      "command": "npm run blog:image -- --slug \"${input:imagePostSlug}\" \"${input:imagePath}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "blog:dev",
      "type": "npm",
      "script": "dev",
      "problemMatcher": []
    },
    {
      "label": "blog:build",
      "type": "npm",
      "script": "build",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "postTitle",
      "type": "promptString",
      "description": "Post title"
    },
    {
      "id": "postCategory",
      "type": "promptString",
      "description": "Category",
      "default": ""
    },
    {
      "id": "postTags",
      "type": "promptString",
      "description": "Tags, comma-separated",
      "default": ""
    },
    {
      "id": "imagePostSlug",
      "type": "promptString",
      "description": "Post slug"
    },
    {
      "id": "imagePath",
      "type": "promptString",
      "description": "Absolute image path"
    }
  ]
}
